{
  "name": "anyqueue",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "build-favicon": "rm public/favicon.ico && npx icon-gen -i src/assets/favicon.svg -o public --ico --ico-name favicon",
    "lint": "vue-cli-service lint"
  },
  "dependencies": {
    "@vue/cli-plugin-babel": "^5.0.8",
    "bootstrap": "5.3.3",
    "bootstrap-icons": "^1.13.1",
    "d3-dsv": "2.0.0",
    "json-url": "2.6.0",
    "lodash": "4.17.21",
    "player.js": "0.1.0",
    "video.js": "^7.15.4",
    "vue": "^3.5.39",
    "vue-async-computed": "^4.0.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.25.1",
    "@vue/cli-plugin-eslint": "^5.0.8",
    "@vue/cli-service": "^5.0.8",
    "@vue/compiler-sfc": "^3.5.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.21.1",
    "icon-gen": "^2.1.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "rules": {
      "vue/multi-word-component-names": "warn",
      "vue/no-mutating-props": "warn"
    },
    "parserOptions": {
      "parser": "@babel/eslint-parser",
      "requireConfigFile": false
    }
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ],
  "keywords": [],
  "description": "",
  "packageManager": "pnpm@11.6.0"
}
